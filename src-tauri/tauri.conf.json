{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PLI PAT Schema Builder",
  "version": "1.2.0",
  "identifier": "pli-pat-schema-builder",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PLI PAT Schema Builder",
        "width": 1000,
        "height": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null,
    "fs": null
  }
}
